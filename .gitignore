## Ignore Visual Studio temporary files, build results, and files generated by popular Visual Studio add-ons.
# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto-generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/
[Log]s/
[Ff]ormat/

# Visual Studio 2015/2017 cache directory
.vs/
# Generated user files
/TestResults/
/OpenCover/

# Roslyn cache directories
*.osxsgn

# RxBxml Cache
_ReSharper*/
*.[Re]Sharper.user
*.DotSettings.user

# Rider
.idea/

# Visual Studio Code
.vscode/

# Local History for Visual Studio Code
.history/

# Windows image analyses
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Database
*.db
*.sqlite

# Docker
.dockerignore
